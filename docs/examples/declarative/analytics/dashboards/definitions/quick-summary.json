{
  "tiles": [
    {
      "definition": {
        "chart": {
          "chart_title": "Total traffic over time",
          "type": "timeseries_line"
        },
        "query": {
          "datasource": "api_usage",
          "dimensions": [
            "time"
          ],
          "metrics": [
            "request_count"
          ]
        }
      },
      "layout": {
        "position": {
          "col": 0,
          "row": 0
        },
        "size": {
          "cols": 6,
          "rows": 2
        }
      },
      "type": "chart"
    },
    {
      "definition": {
        "chart": {
          "chart_title": "Top 5 gateway services by requests",
          "stacked": true,
          "type": "horizontal_bar"
        },
        "query": {
          "datasource": "api_usage",
          "dimensions": [
            "gateway_service"
          ],
          "filters": [
            {
              "field": "gateway_service",
              "operator": "not_empty"
            }
          ],
          "metrics": [
            "request_count"
          ]
        }
      },
      "layout": {
        "position": {
          "col": 0,
          "row": 2
        },
        "size": {
          "cols": 2,
          "rows": 2
        }
      },
      "type": "chart"
    },
    {
